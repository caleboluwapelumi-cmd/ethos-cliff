# Copy to .env.local and fill in real values. .env.local is gitignored — never commit real secrets.

# From the downloaded service account JSON key file:
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# The long ID string in the Google Sheet's URL, between /d/ and /edit
GOOGLE_SHEET_ID=
